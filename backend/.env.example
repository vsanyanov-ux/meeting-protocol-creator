# Yandex Cloud Configuration
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_API_KEY=your_api_key_here

# Yandex Object Storage (Required for audio > 30s)
YANDEX_ACCESS_KEY=your_s3_access_key_here
YANDEX_SECRET_KEY=your_s3_secret_key_here
YANDEX_S3_BUCKET=your_bucket_name_here

# SMTP Configuration (for sending emails)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Target Recipient
RECIPIENT_EMAIL=v.s.anyanov@gmail.com

# Model selection for Yandex GPT (e.g. yandexgpt/latest)
YANDEX_GPT_MODEL=yandexgpt/latest
