# Provider setup (yandex | local | sber)
AI_PROVIDER=yandex
# How many documents to process at the same time (protects CPU/RAM)
MAX_CONCURRENT_TASKS=2

# Yandex Cloud (SpeechKit + GPT)
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_API_KEY=your_api_key_here

# Yandex Object Storage (Required for audio > 30s)
YANDEX_ACCESS_KEY=your_s3_access_key_here
YANDEX_SECRET_KEY=your_s3_secret_key_here
YANDEX_S3_BUCKET=your_bucket_name_here

# SMTP Configuration (for sending emails)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Target Recipient
RECIPIENT_EMAIL=v.s.anyanov@gmail.com

# Model selection for Yandex GPT (e.g. yandexgpt/latest)
YANDEX_GPT_MODEL=yandexgpt/latest

# Security: Allowed CORS origins (comma-separated)
# Dev: http://localhost:5173,http://localhost:3000
# Prod: https://your-company-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -------------------------------------------------------
# Langfuse LLM Observability (опционально)
# Зарегистрируйтесь на https://cloud.langfuse.com (бесплатно)
# Или задеплойте self-hosted: https://langfuse.com/docs/deployment/self-host
# -------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
# Для закрытого контура (self-hosted):
# LANGFUSE_HOST=http://your-internal-langfuse-server:3000
